import sys
import json

def main():
    if len(sys.argv) != 2:
        print('Invalid argument count. Please provide a single path to a text file.', file=sys.stderr)
        sys.exit(1)

    file_path = sys.argv[1]
    try:
        with open(file_path, 'r', encoding='utf-8') as file:
            content = file.read()
    except IOError:
        print('Error reading the file.', file=sys.stderr)
        sys.exit(2)

    line_count = len(content.splitlines())
    word_count = len(content.split())
    char_count = len(content)
    nonempty_line_count = len([line for line in content.splitlines() if line.strip()])

    result = {
        'line_count': line_count,
        'word_count': word_count,
        'char_count': char_count,
        'nonempty_line_count': nonempty_line_count
    }

    print(json.dumps(result))

if __name__ == '__main__':
    main()


