    parser.add_argument('path_to_text_file', type=str, help='Path to the UTF-8 text file')
    
    args = parser.parse_args()
    
    if len(args.path_to_text_file) != 1:
        print("Error: Exactly one argument is required.", file=sys.stderr)
        sys.exit(1)
    
    metrics = count_metrics(args.path_to_text_file)
    print(json.dumps(metrics))

if __name__ == "__main__":
    main()
```

