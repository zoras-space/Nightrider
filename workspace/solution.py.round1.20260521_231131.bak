import sys

def main():
    try:
        input_data = sys.stdin.read()
        lines = input_data.splitlines()
        count = sum(1 for line in lines if "No Rows" in line.strip())
        print(count)
    except Exception as e:
        sys.stderr.write(f"Error: {e}\n")
        sys.exit(1)

if __name__ == "__main__":
    main()
